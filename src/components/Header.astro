---
import { siteConfig } from "../config";
---

<header class="w-full px-6 py-4 flex items-center justify-between bg-slate-900 text-gray-200">
  <!-- LEFT: NAME -->
  <div class="text-xl font-bold">
    {siteConfig.name}
  </div>

  <!-- CENTER: NAV -->
  <nav class="hidden md:flex gap-6 text-sm">
    <a href="#about" class="hover:text-white transition">About</a>
    <a href="#projects" class="hover:text-white transition">Projects</a>
    <a href="#experience" class="hover:text-white transition">Experience</a>
    <a href="#education" class="hover:text-white transition">Education</a>
  </nav>

  <!-- RIGHT: ICONS -->
  <div class="flex items-center gap-4">
    <!-- EMAIL -->
    <a href={`mailto:${siteConfig.socials.email}`} aria-label="Email" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hover:text-white transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16v16H4z"/>
        <path d="m22 6-10 7L2 6"/>
      </svg>
    </a>

    <!-- LINKEDIN -->
    <a href={siteConfig.socials.linkedin} aria-label="LinkedIn" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hover:text-white transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
        <rect width="4" height="12" x="2" y="9"/>
        <circle cx="4" cy="4" r="2"/>
      </svg>
    </a>

    <!-- GITHUB -->
    <a href={siteConfig.socials.github} aria-label="GitHub" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hover:text-white transition" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.49v-1.7c-2.78.6-3.37-1.34-3.37-1.34a2.65 2.65 0 0 0-1.11-1.46c-.91-.62.07-.61.07-.61a2.1 2.1 0 0 1 1.53 1.03 2.12 2.12 0 0 0 2.9.83 2.12 2.12 0 0 1 .63-1.33c-2.22-.25-4.56-1.11-4.56-4.94a3.87 3.87 0 0 1 1.03-2.69 3.6 3.6 0 0 1 .1-2.65s.84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02a3.6 3.6 0 0 1 .1 2.65 3.87 3.87 0 0 1 1.03 2.69c0 3.84-2.34 4.69-4.57 4.93a2.38 2.38 0 0 1 .68 1.85v2.75c0 .27.18.59.69.49A10 10 0 0 0 12 2z"/>
      </svg>
    </a>
  </div>
</header>
