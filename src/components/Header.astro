---
import { siteConfig } from "../config";
---

<header class="w-full px-6 py-4 flex items-center justify-between bg-slate-900 text-gray-200 sticky top-0 z-50">
  <div>
    <div class="text-xl font-bold">{siteConfig.name}</div>
    <p class="text-xs text-gray-400 mt-1 max-w-xs">
      Data Analyst & Financial Analyst specializing in Power BI, SQL, and business insights.
    </p>
  </div>

  <div class="flex items-center gap-5 text-gray-300">
    <a href={`mailto:${siteConfig.socials.email}`} class="hover:text-white">Email</a>
    <a href={siteConfig.socials.linkedin} target="_blank" class="hover:text-white">LinkedIn</a>
    <a href={siteConfig.socials.github} target="_blank" class="hover:text-white">GitHub</a>
  </div>
</header>
