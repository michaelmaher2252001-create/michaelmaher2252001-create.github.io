---
import siteConfig from "../config.ts";
---

<header class="w-full px-6 py-4 flex items-center justify-between bg-slate-900 text-gray-200 sticky top-0 z-50">
  <div>
    <div class="text-xl font-bold">
      {siteConfig.name}
    </div>
    <p class="text-xs text-gray-400 mt-1">
      {siteConfig.role}
    </p>
  </div>

  <div class="flex gap-4">
    <a
      href="https://wa.me/201013559339"
      class="hover:text-white transition"
      target="_blank"
    >
      WhatsApp
    </a>

    <a
      href={`mailto:${siteConfig.socials.email}`}
      class="hover:text-white transition"
    >
      Email
    </a>

    <a
      href={siteConfig.socials.linkedin}
      class="hover:text-white transition"
      target="_blank"
    >
      LinkedIn
    </a>
  </div>
</header>
``
