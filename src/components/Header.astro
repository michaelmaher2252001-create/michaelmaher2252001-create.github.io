---
import { siteConfig } from "../config.ts";
---

<header class="w-full px-6 py-4 flex items-center justify-between bg-slate-900 text-gray-200 sticky top-0 z-50">
  <div>
    <div class="text-xl font-bold">
      {siteConfig.name}
    </div>
    <p class="text-xs text-gray-400 mt-1 max-w-xs">
      Data Analyst & Financial Analyst specializing in Power BI, SQL, and business insights.
    </p>
  </div>

  <div class="flex items-center gap-5 text-gray-300">
    <a href="https://wa.me/201013559339" target="_blank" rel="noopener noreferrer">
      WhatsApp
    </a>

    <a href={`mailto:${siteConfig.socials.email}`}>
      Email
    </a>

    <a href={siteConfig.socials.linkedin} target="_blank" rel="noopener noreferrer">
      LinkedIn
    </a>
  </div>
</header>
``
