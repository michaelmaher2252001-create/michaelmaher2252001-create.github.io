---
import siteConfig from "../config.ts";

const education = siteConfig.education || [];
---

<section class="py-24 bg-slate-900">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-white mb-10">
      Education
    </h2>

    <div class="space-y-8">
      {education.map((item) => (
        <div class="bg-slate-800 p-6 rounded-lg border border-white/5">
          <h3 class="text-xl font-semibold text-white">
            {item.degree}
          </h3>

          <p class="text-gray-400 text-sm">
            {item.school} • {item.dateRange}
          </p>

          <ul class="list-disc list-inside mt-3 text-gray-300 space-y-1">
            {item.achievements.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
``
