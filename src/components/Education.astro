---
import siteConfig from "../config.ts";
const education = siteConfig.education ?? [];
---

<section class="section" id="education">
  <div class="mb-14">
    <span class="badge mb-5">Education</span>

    <h2 class="section-title">
      Finance education strengthened with modern analytics training.
    </h2>
  </div>

  <div class="grid gap-6">
    {education.map((item) => (
      <article class="card p-7 lg:p-8">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
          <div>
            <h3 class="text-xl font-bold text-white">
              {item.degree}
            </h3>

            <p class="text-sky-400 mt-2">
              {item.school}
            </p>
          </div>

          <span class="text-sm text-slate-400 border border-slate-700 rounded-full px-4 py-2 w-fit">
            {item.dateRange}
          </span>
        </div>

        <ul class="grid sm:grid-cols-2 gap-3 text-sm text-slate-400">
          {item.achievements.map((point) => (
            <li class="rounded-xl bg-slate-900/70 border border-slate-700/60 p-4 leading-6">
              {point}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
