---
import siteConfig from "../config.ts";
const education = siteConfig.education ?? [];
---

<section class="max-w-4xl mx-auto px-6 py-32" id="education">
  <h2 class="text-2xl font-medium text-white mb-14">
    Education
  </h2>

  <div class="space-y-12">
    {education.map((item) => (
      <div>
        <h3 class="text-lg text-white mb-1">
          {item.degree}
        </h3>

        <p class="text-gray-400 text-sm mb-3">
          {item.school} · {item.dateRange}
        </p>

        <ul class="list-disc list-inside text-gray-400 text-sm space-y-1">
          {item.achievements.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
