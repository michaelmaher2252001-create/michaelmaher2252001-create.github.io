---
import siteConfig from "../config.ts";
const projects = siteConfig.projects || [];
---

<section class="py-32 bg-slate-800">
  <div class="max-w-6xl mx-auto px-6">

    <h2 class="text-2xl font-semibold text-white mb-14 text-center">
      Selected Projects
    </h2>

    <div class="grid md:grid-cols-2 gap-10">
      {projects.map((project) => (
        <div class="bg-slate-700 p-8 rounded-xl border border-white/5 hover:border-white/10 transition">

          <h3 class="text-lg font-medium text-white mb-3">
            {project.title}
          </h3>

          <p class="text-gray-400 text-sm mb-5">
            {project.description}
          </p>

          <ul class="space-y-1 text-gray-300 text-sm mb-6">
            {project.insights.map((item) => (
              <li>• {item}</li>
            ))}
          </ul>

          {project.href && (
            <a
              href={project.href}
              target="_blank"
              class="text-sm text-blue-400 hover:text-blue-300 transition"
            >
              View project →
            </a>
          )}

        </div>
      ))}
    </div>
  </div>
</section>
