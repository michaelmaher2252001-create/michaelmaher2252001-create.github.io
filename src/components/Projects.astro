---
import siteConfig from "../config.ts";
const projects = siteConfig.projects ?? [];
---

<section class="max-w-5xl mx-auto px-6 py-32">
  <h2 class="text-2xl font-medium text-white mb-16">
    Selected Projects
  </h2>

  <div class="space-y-24">

    {projects.map((project) => (
      <div class="text-left">

        <!-- TITLE -->
        <h3 class="text-lg text-white mb-3">
          {project.title}
        </h3>

        <!-- DESCRIPTION -->
        <p class="text-gray-400 max-w-2xl mb-6">
          {project.description}
        </p>

        <!-- ✅ PREMIUM IMAGE -->
        {project.image && (
          <div class="overflow-hidden rounded-xl border border-white/5 mb-8">
            <img
              src={project.image}
              alt={project.title}
              class="w-full max-w-2xl mx-auto transition duration-500 ease-out hover:scale-105"
            />
          </div>
        )}

        <!-- INSIGHTS -->
        <ul class="list-disc list-inside text-sm text-gray-400 space-y-1 mb-5">
          {project.insights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>

        <!-- LINK -->
        {project.href && (
          <a
            href={project.href}
            target="_blank"
            class="text-gray-400 hover:text-white transition"
          >
            View project →
          </a>
        )}

      </div>
    ))}

  </div>
</section>
``
