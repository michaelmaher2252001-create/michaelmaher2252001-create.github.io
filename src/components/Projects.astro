---
import { siteConfig } from "../config";

const projects = Array.isArray(siteConfig.projects)
  ? siteConfig.projects
  : [];
---

{projects.length > 0 && (
  <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
    <div class="space-y-6">
      <h2 class="text-4xl font-bold text-gray-900">Projects</h2>

      {projects.map((project) => (
        <a
          href={project.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block p-6 bg-gray-50 border rounded-xl hover:shadow-md transition"
        >
          <h3 class="text-xl font-semibold">{project.title}</h3>
          <p class="text-gray-600 mt-2">{project.description}</p>
        </a>
      ))}
    </div>
  </section>
)}
