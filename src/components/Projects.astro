---
import siteConfig from "../config.ts";
const projects = siteConfig.projects ?? [];
---

<section class="max-w-5xl mx-auto px-6 py-32">
  <h2 class="text-2xl font-medium text-white mb-16">
    Selected Projects
  </h2>

  <div class="space-y-16">
    {projects.map((project) => (
      <div>
        <h3 class="text-lg text-white mb-2">
          {project.title}
        </h3>

        <p class="text-gray-400 max-w-2xl mb-4">
          {project.description}
        </p>

        <ul class="list-disc list-inside text-gray-400 text-sm space-y-1 mb-4">
          {project.insights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>

        {project.href && (
          <a
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-blue-400 hover:underline"
          >
            View project →
          </a>
        )}
      </div>
    ))}
  </div>
</section>
