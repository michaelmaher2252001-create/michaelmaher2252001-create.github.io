---
import siteConfig from "../config.ts";

const projects = siteConfig.projects ?? [];
---

<section id="projects" class="projects-section">

  <div class="projects-glow"></div>

  <div class="projects-container">

    <div class="projects-heading">

      <span class="projects-badge">
        Selected <strong>Projects</strong>
      </span>

      <h2 class="projects-title">
        Practical analytics projects built around business decisions.
      </h2>

      <div class="projects-line"></div>

      <p class="projects-subtitle">
        A selection of Power BI and financial analysis projects focused on
        performance, profitability, risk monitoring, and executive reporting.
      </p>

    </div>

    <div class="projects-list">
      {projects.map((project) => (
        <article class="project-card">

          <div class="project-content">

            <div class="project-tag">
              {project.category}
            </div>

            <h3>
              {project.title}
            </h3>

            <p class="project-description">
              {project.description}
            </p>

            {project.tags && (
              <div class="tech-stack">
                {project.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            )}

            {project.insights && (
              <div class="project-section">
                <h4>Key Insights</h4>

                <ul>
                  {project.insights.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            )}

            {project.impact && (
              <div class="project-section">
                <h4>Business Impact</h4>

                <ul>
                  {project.impact.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            )}

            {project.href && (
              <a href={project.href} target="_blank" class="project-link">
                View Project →
              </a>
            )}

          </div>

          {project.image && (
            <div class="project-image-wrap">
              <img src={project.image} alt={project.title} class="project-image" />
            </div>
          )}

        </article>
      ))}
    </div>

  </div>

</section>

<style>
  .projects-section {
    position: relative;
    padding: 120px 24px;
    overflow: hidden;
  }

  .projects-glow {
    position: absolute;
    top: 120px;
    left: 50%;
    width: 750px;
    height: 750px;
    transform: translateX(-50%);
    border-radius: 999px;
    background:
      radial-gradient(circle, rgba(34, 211, 238, 0.12), transparent 60%),
      radial-gradient(circle, rgba(74, 222, 128, 0.06), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }

  .projects-container {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
  }

  .projects-heading {
    text-align: center;
    margin-bottom: 80px;
  }

  .projects-badge {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-size: 58px;
    font-weight: 950;
    line-height: 1;
    letter-spacing: -0.05em;
    color: white;
    margin-bottom: 26px;
  }

  .projects-badge strong {
    color: #22d3ee;
  }

  .projects-title {
    margin: 0;
    color: white;
    font-size: clamp(2.7rem, 4vw, 3.5rem);
    line-height: 1.1;
    font-weight: 950;
    letter-spacing: -0.05em;
    max-width: 1000px;
    margin-inline: auto;
  }

  .projects-line {
    width: 88px;
    height: 3px;
    margin: 28px auto;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, #22d3ee, transparent);
    box-shadow: 0 0 30px rgba(34, 211, 238, 0.75);
  }

  .projects-subtitle {
    max-width: 760px;
    margin: 0 auto;
    color: #94a3b8;
    font-size: 18px;
    line-height: 1.9;
  }

  .projects-list {
    display: grid;
    gap: 42px;
  }

  .project-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 34px;
    padding: 38px;
    border-radius: 36px;
    background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.55));
    box-shadow:
      0 30px 90px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(24px);
    transition: 0.25s ease;
  }

  .project-card:hover {
    transform: translateY(-6px);
  }

  .project-tag {
    display: inline-flex;
    padding: 10px 18px;
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.1);
    color: #22d3ee;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 24px;
  }

  .project-card h3 {
    margin: 0;
    color: white;
    font-size: 34px;
    line-height: 1.12;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .project-description {
    margin-top: 22px;
    color: #cbd5e1;
    font-size: 17px;
    line-height: 1.8;
    max-width: 900px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .tech-stack span {
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: #cbd5e1;
    font-size: 13px;
    font-weight: 600;
  }

  .project-section {
    margin-top: 32px;
  }

  .project-section h4 {
    margin: 0 0 16px;
    color: white;
    font-size: 20px;
    font-weight: 900;
  }

  .project-section ul {
    margin: 0;
    padding-left: 22px;
  }

  .project-section li {
    color: #cbd5e1;
    font-size: 16px;
    line-height: 1.9;
  }

  .project-link {
    display: inline-flex;
    margin-top: 34px;
    padding: 14px 22px;
    border-radius: 999px;
    background: #22d3ee;
    color: #031018;
    font-weight: 800;
    text-decoration: none;
  }

  .project-image-wrap {
    overflow: hidden;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.04);
  }

  .project-image {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .projects-section {
      padding: 90px 20px;
    }

    .projects-badge {
      font-size: 42px;
    }

    .projects-title {
      font-size: 2.4rem;
    }

    .project-card {
      padding: 28px;
    }

    .project-card h3 {
      font-size: 30px;
    }
  }
</style>
