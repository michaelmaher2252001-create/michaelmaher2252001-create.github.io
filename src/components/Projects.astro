---
import siteConfig from "../config.ts";
const projects = siteConfig.projects ?? [];
---

<section id="projects" class="section">
  <div class="mb-14">
    <span class="badge mb-5">Selected Projects</span>

    <h2 class="max-w-3xl text-4xl md:text-5xl font-extrabold tracking-tight text-white">
      Practical analytics projects built around business decisions.
    </h2>

    <p class="mt-6 max-w-2xl text-slate-400 leading-7">
      A selection of Power BI and financial analysis projects focused on
      performance, profitability, risk monitoring, and executive reporting.
    </p>
  </div>

  <div class="grid gap-8">
    {projects.map((project) => (
      <article class="card overflow-hidden">
        <div class="grid lg:grid-cols-2 gap-0">

          <div class="p-8 lg:p-10">
            <span class="badge mb-4">
              {project.category}
            </span>

            <h3 class="text-2xl font-bold text-white mb-4">
              {project.title}
            </h3>

            <p class="text-slate-400 leading-7 mb-6">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2 mb-8">
              {project.tags?.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>

            <div class="space-y-6">

              <div>
                <h4 class="text-white font-semibold mb-3">
                  Key Insights
                </h4>

                <ul class="space-y-2 text-slate-400">
                  {project.insights?.map((item) => (
                    <li class="flex gap-3">
                      <span class="mt-2 h-1.5 w-1.5 rounded-full bg-cyan-400"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div>
                <h4 class="text-white font-semibold mb-3">
                  Business Impact
                </h4>

                <ul class="space-y-2 text-slate-400">
                  {project.impact?.map((item) => (
                    <li class="flex gap-3">
                      <span class="mt-2 h-1.5 w-1.5 rounded-full bg-cyan-400"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

            </div>

            <a
              href={project.href}
              target="_blank"
              class="btn-primary inline-flex mt-8"
            >
              View Project →
            </a>
          </div>

          <div class="border-t lg:border-t-0 lg:border-l border-white/10 bg-[#071120] p-6 flex items-center justify-center">
            <img
              src={project.image}
              alt={project.title}
              class="rounded-2xl border border-white/10 shadow-2xl w-full object-cover"
            />
          </div>

        </div>
      </article>
    ))}
  </div>
</section>
