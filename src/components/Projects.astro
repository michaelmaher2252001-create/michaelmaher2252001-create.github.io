---
import siteConfig from "../config.ts";
const projects = siteConfig.projects || [];
---

<section class="py-28 bg-slate-900">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-white mb-14 text-center">
      Projects
    </h2>

    <div class="grid md:grid-cols-2 gap-10">
      {projects.map((project) => (
        <div
          class="bg-slate-800 rounded-xl border border-white/5
                 shadow-lg hover:shadow-xl transition
                 overflow-hidden"
        >
          <!-- PROJECT CONTENT -->
          <div class="p-6">
            <h3 class="text-xl font-semibold text-white mb-2">
              {project.title}
            </h3>

            <p class="text-gray-400 text-sm mb-4">
              {project.description}
            </p>

            <ul class="list-disc list-inside text-gray-300 text-sm space-y-1 mb-6">
              {project.insights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>

            {project.href && (
              <a
                href={project.href}
                target="_blank"
                class="inline-block text-sm text-blue-400
                       hover:text-blue-300 transition"
              >
                View Project →
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
