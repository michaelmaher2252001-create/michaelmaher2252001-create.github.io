---
import siteConfig from "../config.ts";
const projects = siteConfig.projects ?? [];
---

<section class="max-w-5xl mx-auto px-6 py-32">
  <h2 class="text-2xl font-medium text-white mb-16">
    Selected Projects
  </h2>

  <div class="space-y-20">

    {projects.map((project) => (
      <div class="text-left">

        <!-- TITLE -->
        <h3 class="text-lg text-white mb-3">
          {project.title}
        </h3>

        <!-- DESCRIPTION -->
        <p class="text-gray-400 max-w-2xl mb-5">
          {project.description}
        </p>

