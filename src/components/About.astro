---
import siteConfig from "../config.ts";
const projects = siteConfig.projects ?? [];
---

<section class="section" id="projects">
  <div class="mb-14">
    <span class="badge mb-5">Selected Projects</span>

    <h2 class="section-title">
      Practical analytics projects built around business decisions.
    </h2>

    <p class="section-subtitle">
      A selection of Power BI and financial analysis projects focused on performance,
      profitability, risk monitoring, and executive reporting.
    </p>
  </div>

  <div class="grid gap-8">
    {projects.map((project) => (
      <article class="card overflow-hidden grid lg:grid-cols-[1fr_1.1fr] gap-0">
        <div class="p-7 lg:p-9 flex flex-col">
          <p class="text-sm text-sky-400 font-semibold mb-3">
            {project.category}
          </p>

          <h3 class="text-2xl font-bold text-white tracking-tight mb-4">
            {project.title}
          </h3>

          <p class="text-slate-400 leading-7 mb-6">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-2 mb-8">
            {project.tools?.map((tool) => (
              <span class="text-xs px-3 py-1 rounded-full bg-slate-900/80 border border-slate-700 text-slate-300">
                {tool}
              </span>
            ))}
          </div>

          <div class="grid sm:grid-cols-2 gap-6 mb-8">
            <div>
              <h4 class="text-sm font-semibold text-white mb-3">
                Key Insights
              </h4>

              <ul class="space-y-2 text-sm text-slate-400 leading-6">
                {project.insights.map((item) => (
                  <li>• {item}</li>
                ))}
              </ul>
            </div>

            <div>
              <h4 class="text-sm font-semibold text-white mb-3">
                Business Impact
              </h4>

              <ul class="space-y-2 text-sm text-slate-400 leading-6">
                {project.impact.map((item) => (
                  <li>• {item}</li>
                ))}
              </ul>
            </div>
          </div>

          {project.href && (
            <a
              href={project.href}
              target="_blank"
              class="btn-primary w-fit mt-auto"
            >
              View Project →
            </a>
          )}
        </div>

        <div class="bg-slate-950/70 p-5 lg:p-8 flex items-center justify-center border-t lg:border-t-0 lg:border-l border-slate-800">
          {project.image && (
            <img
              src={project.image}
              alt={project.title}
              class="w-full rounded-2xl border border-slate-700 shadow-2xl"
            />
          )}
        </div>
      </article>
    ))}
  </div>
</section>
