---
import siteConfig from "../config.ts";
---

<section id="about" class="section">
  <div class="grid lg:grid-cols-2 gap-12 items-start">

    <div>
      <span class="badge mb-5">About Me</span>

      <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Transforming raw data into business insights and financial clarity.
      </h2>

      <p class="text-slate-400 leading-8 text-lg">
        {siteConfig.about}
      </p>
    </div>

    <div class="card p-8 space-y-6">

      <div>
        <h3 class="text-white font-semibold mb-3">
          Power BI
        </h3>

        <p class="text-slate-400 leading-7">
          Interactive dashboards and KPI reporting
        </p>
      </div>

      <div class="border-t border-white/10 pt-6">
        <h3 class="text-white font-semibold mb-3">
          Finance
        </h3>

        <p class="text-slate-400 leading-7">
          Variance, profitability, and performance analysis
        </p>
      </div>

      <div class="border-t border-white/10 pt-6">
        <h3 class="text-white font-semibold mb-3">
          Insights
        </h3>

        <p class="text-slate-400 leading-7">
          Business storytelling from raw data
        </p>
      </div>

    </div>
  </div>
</section>
