---
import siteConfig from "../config.ts";
---

<section class="section" id="about">
  <div class="grid lg:grid-cols-[0.8fr_1.2fr] gap-12 items-start">
    <div>
      <span class="badge mb-5">About</span>

      <h2 class="section-title">
        Analyst with a finance background and a dashboard-driven mindset.
      </h2>
    </div>

    <div class="card p-7 lg:p-9">
      <p class="text-slate-300 leading-8 mb-8">
        {siteConfig.about}
      </p>

      <div class="grid sm:grid-cols-3 gap-4">
        <div class="rounded-2xl bg-slate-900/70 border border-slate-700/60 p-5">
          <p class="text-2xl font-bold text-white">Power BI</p>
          <p class="text-sm text-slate-400 mt-2">Dashboards</p>
        </div>

        <div class="rounded-2xl bg-slate-900/70 border border-slate-700/60 p-5">
          <p class="text-2xl font-bold text-white">Finance</p>
          <p class="text-sm text-slate-400 mt-2">Analysis</p>
        </div>

        <div class="rounded-2xl bg-slate-900/70 border border-slate-700/60 p-5">
          <p class="text-2xl font-bold text-white">SQL</p>
          <p class="text-sm text-slate-400 mt-2">Data Querying</p>
        </div>
      </div>
    </div>
  </div>
</section>
