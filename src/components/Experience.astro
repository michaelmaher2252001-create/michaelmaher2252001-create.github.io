---
import siteConfig from "../config.ts";

const hasExperience =
  siteConfig.experience && siteConfig.experience.length > 0;
---

{hasExperience && (
  <section class="py-24 bg-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-white mb-10">
        Experience
      </h2>

      <div class="space-y-8">
        {siteConfig.experience.map((item) => (
          <div class="bg-slate-900 p-6 rounded-lg border border-white/5">
            <h3 class="text-xl font-semibold text-white">
              {item.title}
            </h3>
            <p class="text-gray-400 text-sm">
              {item.company} • {item.dateRange}
            </p>
            <ul class="list-disc list-inside mt-3 text-gray-300 space-y-1">
              {item.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
