---
import siteConfig from "../config.ts";
---

<section class="px-6 py-24 max-w-6xl mx-auto text-center">
  <p class="text-xl text-gray-400 mb-4">Hello! 👋</p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10">
    {siteConfig.role}
  </p>

  <div class="flex justify-center gap-6 mt-10 text-white">
    <a
      href="https://wa.me/201013559339"
      class="px-4 py-2 rounded bg-green-600 hover:bg-green-700"
      target="_blank"
    >
      WhatsApp
    </a>

    <a
      href={"mailto:" + siteConfig.socials.email}
      class="px-4 py-2 rounded bg-blue-600 hover:bg-blue-700"
    >
      Email
    </a>

    <a
      href={siteConfig.socials.linkedin}
      class="px-4 py-2 rounded bg-slate-700 hover:bg-slate-600"
      target="_blank"
    >
      LinkedIn
    </a>
  </div>
</section>
