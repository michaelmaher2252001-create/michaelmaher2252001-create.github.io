    {siteConfig.role}
  </p>

  <!-- SAFE CONTACT LINKS -->
  <div class="flex justify-center gap-6 mb-12 text-sm text-gray-300">
    <a href="https://wa.me/201013559339" target="_blank" class="hover:underline">
      WhatsApp
    </a>
    <a href="mailto:michael.maher225200@gmail.com" class="hover:underline">
      Email
    </a>
    <a href="https://www.linkedin.com/in/michael-maher-3104ab216" target="_blank" class="hover:underline">
      LinkedIn
    </a>
  </div>

  <!-- DOWNLOAD CV -->
  <a
    href="/Michael_Maher_CV.pdf"
