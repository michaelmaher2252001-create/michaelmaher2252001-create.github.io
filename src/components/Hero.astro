---
import siteConfig from "../config.ts";
---

<section class="px-6 py-28 max-w-6xl mx-auto text-center bg-slate-950">
  <p class="text-lg text-gray-400 mb-4">
    Hello! 👋
  </p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 mb-10">
    {siteConfig.role}
  </p>

  <!-- CONTACT LINKS -->
  <div class="flex justify-center gap-8 mb-12 text-gray-300 text-sm">

    <a
      href="https://wa.me/201013559339"
      target="_blank"
      class="flex items-center gap-2 hover:text-green-400 transition"
    >
      ✅ WhatsApp Me
