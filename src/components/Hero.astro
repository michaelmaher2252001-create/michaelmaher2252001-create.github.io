---
import { siteConfig } from "../config";
---

<section class="relative px-6 py-24 max-w-6xl mx-auto bg-white">
  <!-- HELLO -->
  <p class="text-xl text-gray-500 mb-4">
    Hello! <span class="inline-block animate-wave">👋</span>
  </p>

  <!-- NAME -->
  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
    I'm {siteConfig.name}
  </h1>

  <!-- ABOUT -->
  <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mb-8">
    Data Analyst & Financial Analyst specializing in Power BI, SQL,
    and turning data into clear business insights.
  </p>

  <!-- CONTACT ICONS (ICONS ONLY, DARK) -->
  <div class="flex items-center gap-6 text-gray-700">
    <!-- PHONE -->
    tel:01013559339
      <svg xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 hover:text-black transition-colors"
        fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.8 19.8 0 0 1 3 5.18
          2 2 0 0 1 5.11 3h3a2 2 0 0 1 2 1.72c.12.81.31 1.6.57 2.35
          a2 2 0 0 1-.45 2.11L9.91 10.91a16 16 0 0 0 6.18 6.18
          l1.73-1.73a2 2 0 0 1 2.11-.45c.75.26 1.54.45 2.35.57
          A2 2 0 0 1 22 16.92z"/>
      </svg>
    </a>

    <!-- EMAIL -->
    {`mailto:${siteConfig.socials.email}`}
      <svg xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 hover:text-black transition-colors"
        fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        <path d="M4 4h16v16H4z"/>
        <path d="m22 6-10 7L2 6"/>
      </svg>
    </a>

    <!-- LINKEDIN -->
    {siteConfig.socials.linkedin}
      <svg xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 hover:text-black transition-colors"
        fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2
          2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
        <rect x="2" y="9" width="4" height="12"/>
        <circle cx="4" cy="4" r="2"/>
      </svg>
    </a>

    <!-- GITHUB -->
    {siteConfig.socials.github}
      <svg xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 hover:text-black transition-colors"
        fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.49v-1.7
          c-2.78.6-3.37-1.34-3.37-1.34a2.65 2.65 0 0 0-1.11-1.46
          c-.91-.62.07-.61.07-.61a2.1 2.1 0 0 1 1.53 1.03
          a2.12 2.12 0 0 0 2.9.83 2.12 2.12 0 0 1 .63-1.33
          c-2.22-.25-4.56-1.11-4.56-4.94a3.87 3.87 0 0 1
          1.03-2.69 3.6 3.6 0 0 1 .1-2.65s.84-.27 2.75 1.02
          a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02
          2.75-1.02a3.6 3.6 0 0 1 .1 2.65
          a3.87 3.87 0 0 1 1.03 2.69
          c0 3.84-2.34 4.69-4.57 4.93
          a2.38 2.38 0 0 1 .68 1.85v2.75
          c0 .27.18.59.69.49A10 10 0 0 0 12 2z"/>
      </svg>
    </a>
  </div>
</section>
