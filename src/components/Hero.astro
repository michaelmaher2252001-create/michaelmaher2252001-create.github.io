---
import siteConfig from "../config.ts";
---

<section class="px-6 py-36 max-w-6xl mx-auto text-center
               bg-gradient-to-b from-slate-950 via-slate-900 to-slate-900">

  <p class="text-xl text-gray-400 mb-4">
    Hello! 👋
  </p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-14">
    {siteConfig.role}
  </p>

  <!-- ICON CONTACTS -->
  <div class="flex justify-center gap-6 mb-14">

    <!-- WhatsApp -->
    <a
      href="https://wa.me/201013559339"
      target="_blank"
      class="w-12 h-12 rounded-full bg-slate-800
             flex items-center justify-center
             hover:bg-green-500 transition"
      aria-label="WhatsApp"
    >
      <svg viewBox="0 0 32 32" class="w-5 h-5 fill-white">
        <path d="M16 2C8.3 2 2 8.3 2 16c0 2.7.8 5.4 2.3
        7.7L2 30l6.5-2c2.2 1.2 4.8 2 7.5
        2 7.7 0 14-6.3 14-14S23.7 2 16 2z"/>
      </svg>
    </a>

    <!-- Email -->
    <a
      href={`mailto:${siteConfig.socials.email}`}
      class="w-12 h-12 rounded-full bg-slate-800
             flex items-center justify-center
             hover:bg-slate-700 transition"
      aria-label="Email"
    >
      <svg viewBox="0 0 24 24" class="w-5 h-5 fill-white">
        <path d="M4 4h16v16H4z"/>
        <path d="m22 6-10 7L2 6"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a
      href={siteConfig.socials.linkedin}
      target="_blank"
      class="w-12 h-12 rounded-full bg-slate-800
             flex items-center justify-center
             hover:bg-blue-500 transition"
      aria-label="LinkedIn"
    >
      <svg viewBox="0 0 24 24" class="w-5 h-5 fill-white">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2
        2 0 0 0-2-2 2
        2 0 0 0-2 2v7h-4v-7a6
        6 0 0 1 6-6z"/>
        <rect x="2" y="9" width="4" height="12"/>
        <circle cx="4" cy="4" r="2"/>
      </svg>
    </a>

  </div>

  <!-- DOWNLOAD CV -->
  <a
    href="/Michael_Maher_CV.pdf"
    download
    class="inline-flex items-center gap-2
           px-7 py-3 rounded-full
           bg-white text-slate-900
           font-medium shadow
           hover:shadow-lg hover:scale-105
           transition"
  >
    Download CV
  </a>

</section>
