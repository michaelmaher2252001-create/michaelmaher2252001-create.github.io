--- "../config.ts";
---

<section class="px-6 py-28 max-w-6xl mx-auto text-center">
  <p class="text-lg text-gray-400 mb-4">
    Hello! 👋
  </p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 mb-10">
    {siteConfig.role}
  </p>

  <!-- CONTACT LINKS (SAFE + PROFESSIONAL) -->
  <div class="flex justify-center gap-8 mb-12 text-gray-300 text-sm">

    <a
      href="https://wa.me/201013559339"
      target="_blank"
      class="flex items-center gap-2 hover:text-green-400 transition"
    >
      ✅ WhatsApp Me
    </a>

    <a
      href="mailto:michael.maher225200@gmail.com"
      class="flex items-center gap-2 hover:text-white transition"
    >
      ✉ Email
    </a>

    <a
      href="https://www.linkedin.com/in/michael-maher-3104ab216"
      target="_blank"
      class="flex items-center gap-2 hover:text-blue-400 transition"
    >
      🔗 LinkedIn
    </a>

  </div>

  <!-- DOWNLOAD CV -->
  <a
    href="/Michael_Maher_CV.pdf"
    download
    class="inline-block px-6 py-3 rounded-full bg-white text-slate-900
           font-medium shadow hover:shadow-lg hover:scale-105 transition"
  >
    Download CV
  </a>
</section>
