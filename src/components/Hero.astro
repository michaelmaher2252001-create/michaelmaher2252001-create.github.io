---
import siteConfig from "../config.ts";
---

<section class="px-6 py-28 max-w-6xl mx-auto text-center">
  <p class="text-lg text-gray-400 mb-4">Hello! 👋</p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 mb-12">
    {siteConfig.role}
  </p>

  <!-- APP-LIKE CONTACT ICONS -->
  <div class="flex justify-center gap-6 mb-12">

    <!-- WhatsApp -->
    href="https://wa.me/201013559339" target="_blank" title="WhatsApp Me"
      class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center
             shadow-md hover:shadow-lg hover:scale-105 transition"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"
           class="w-6 h-6 text-green-400 fill-current">
        <path d="M16.003 2.002C8.282 2.002 2 8.285 2 16.006
        c0 2.864.743 5.645 2.155 8.117L2 30l6.027-2.084
        a13.94 13.94 0 0 0 7.976 2.45c7.721 0
        14.003-6.283 14.003-14.004
        0-7.72-6.282-14.36-14.004-14.36z"/>
      </svg>
    </a>

    <!-- Email -->
    href={"mailto:" + siteConfig.socials.email} title="Email Me"
      class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center
             shadow-md hover:shadow-lg hover:scale-105 transition"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
           class="w-6 h-6 text-gray-200 fill-current">
        <path d="M4 4h16v16H4z"/>
        <path d="m22 6-10 7L2 6"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    href={siteConfig.socials.linkedin} target="_blank" title="LinkedIn"
      class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center
             shadow-md hover:shadow-lg hover:scale-105 transition"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
           class="w-6 h-6 text-blue-400 fill-current">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2
        2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6
        6 0 0 1 6-6z"/>
        <rect x="2" y="9" width="4" height="12"/>
        <circle cx="4" cy="4" r="2"/>
      </svg>
    </a>

  </div>

  <!-- DOWNLOAD CV BUTTON -->
  href="/Michael_Maher_CV.pdf" download
    class="inline-block px-6 py-3 rounded-full bg-white text-slate-900
           font-medium shadow hover:shadow-lg hover:scale-105 transition"
  >
    Download CV
  </a>
</section>
