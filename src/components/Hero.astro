---
import siteConfig from "../config.ts";
---

<section class="section min-h-screen flex items-center">
  <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-12 items-center w-full">
    <div>
      <div class="badge mb-6">
        {siteConfig.hero?.eyebrow ?? siteConfig.role}
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-white leading-[0.95] mb-6">
        {siteConfig.hero?.headline}
      </h1>

      <p class="text-lg text-slate-400 leading-8 max-w-2xl mb-10">
        {siteConfig.hero?.subheadline}
      </p>

      <div class="flex flex-wrap gap-4 mb-10">
        <a href="#projects" class="btn-primary">
          View Projects
        </a>

        <a href={`mailto:${siteConfig.socials.email}`} class="btn-secondary">
          Contact Me
        </a>

        <a href="/Michael_Maher_CV.pdf" download class="btn-secondary">
          Download CV
        </a>
      </div>

      <div class="flex flex-wrap gap-6 text-sm text-slate-400">
        <a href="https://wa.me/201013559339" class="hover:text-white transition">
          WhatsApp
        </a>

        <a href={`mailto:${siteConfig.socials.email}`} class="hover:text-white transition">
          Email
        </a>

        <a href={siteConfig.socials.linkedin} target="_blank" class="hover:text-white transition">
          LinkedIn
        </a>

        <a href={siteConfig.socials.github} target="_blank" class="hover:text-white transition">
          GitHub
        </a>
      </div>
    </div>

    <div class="card p-6 lg:p-8">
      <p class="text-sm text-slate-400 mb-6">
        Portfolio Focus
      </p>

      <div class="space-y-5">
        <div class="p-5 rounded-2xl bg-slate-900/70 border border-slate-700/60">
          <p class="text-3xl font-bold text-white">Power BI</p>
          <p class="text-sm text-slate-400 mt-2">
            Interactive dashboards and KPI reporting
          </p>
        </div>

        <div class="p-5 rounded-2xl bg-slate-900/70 border border-slate-700/60">
          <p class="text-3xl font-bold text-white">Finance</p>
          <p class="text-sm text-slate-400 mt-2">
            Variance, profitability, and performance analysis
          </p>
        </div>

        <div class="p-5 rounded-2xl bg-slate-900/70 border border-slate-700/60">
          <p class="text-3xl font-bold text-white">Insights</p>
          <p class="text-sm text-slate-400 mt-2">
            Business storytelling from raw data
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
