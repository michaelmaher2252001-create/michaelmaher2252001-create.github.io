---
import siteConfig from "../config.ts";
---

<section class="px-6 py-28 max-w-6xl mx-auto text-center">
  <p class="text-lg text-gray-400 mb-4">Hello! 👋</p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 mb-12">
    {siteConfig.role}
  </p>

  <!-- APP ICONS -->
  <div class="flex justify-center gap-6 mb-12">

    <!-- WhatsApp -->
    <a
      href="https://wa.me/201013559339"
      target="_blank"
      class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center shadow-md hover:shadow-lg hover:scale-105 transition"
      title="WhatsApp Me"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-6 h-6 fill-current text-green-400">
        <path d="M16.003 2.002C8.282 2.002 2 8.285 2 16.006c0 2.864.743 5.645 2.155 8.117L2 30l6.027-2.084a13.94 13.94 0 0 0 7.976 2.45c7.721 0 14.003-6.283 14.003-14.004 0-7.72-6.282-14.36-14.004-14.36z"/>
      </svg>
