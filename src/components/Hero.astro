---
import siteConfig from "../config.ts";
---

<section class="max-w-4xl mx-auto px-6 py-40 text-center">
  <h1 class="text-5xl sm:text-6xl font-medium text-white tracking-tight mb-6">
    {siteConfig.name}
  </h1>

  <p class="text-xl text-gray-400 max-w-xl mx-auto mb-16">
    {siteConfig.role}
  </p>

  <div class="flex justify-center gap-10 text-sm text-gray-400 mb-20">
    <a href="https://wa.me/201013559339" class="hover:text-white transition">
      WhatsApp
    </a>

    <a href={`mailto:${siteConfig.socials.email}`} class="hover:text-white transition">
      Email
    </a>

    <a href={siteConfig.socials.linkedin} class="hover:text-white transition">
      LinkedIn
    </a>
  </div>

  <a
    href="/Michael_Maher_CV.pdf"
    download
    class="text-sm text-white underline underline-offset-4 hover:opacity-70 transition"
  >
    Download CV
  </a>
</section>
