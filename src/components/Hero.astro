---
import { siteConfig } from "../config";
---

<section class="px-6 py-24 max-w-6xl mx-auto">
  <p class="text-xl text-gray-400 mb-4">
    Hello! <span class="inline-block">👋</span>
  </p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-gray-100 mb-6">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mb-8">
    {siteConfig.role}
  </p>
</section>
``
