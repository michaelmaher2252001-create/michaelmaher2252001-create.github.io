---
import siteConfig from "../config.ts";
---

<section class="px-6 py-24 max-w-6xl mx-auto text-center">
  <p class="text-xl text-gray-400 mb-4">
    Hello! 👋
  </p>

  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
    I'm {siteConfig.name}
  </h1>

  <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10">
    {siteConfig.role}
  </p>

  <!-- CONTACT ICONS -->
  <div class="flex justify-center gap-6 mb-10 text-gray-300">

    <!-- WhatsApp -->
    https://wa.me/201013559339 target="_blank" aria-label="WhatsApp"
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"
        class="w-7 h-7 fill-current hover:text-green-400 transition">
        <path d="M16.003 2.002C8.282 2.002 2 8.285 2 16.006c0 2.864.743
        5.645 2.155 8.117L2 30l6.027-2.084a13.94
        13.94 0 0 0 7.976 2.45h.001c7.721 0
        14.003-6.283 14.003-14.004
        0-7.72-6.282-14.36-14.004-14.36z"/>
      </svg>
    </a>

    <!-- Email -->
    {"mailto:" + siteConfig.socials.email} aria-label="Email"
      <svg xmlns="http://www.w3.org/2000/svg"
        class="w-7 h-7 fill-current hover:text-white transition"
        viewBox="0 0 24 24">
        <path d="M4 4h16v16H4z"/>
        <path d="m22 6-10 7L2 6"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    {siteConfig.socials.linkedin} target="_blank" aria-label="LinkedIn"
      <svg xmlns="http://www.w3.org/2000/svg"
        class="w-7 h-7 fill-current hover:text-blue-400 transition"
        viewBox="0 0 24 24">

