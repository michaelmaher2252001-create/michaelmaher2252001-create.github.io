---
import siteConfig from "../config.ts";

const skills = siteConfig.skills ?? {};
---

<section class="section" id="skills">
  <div class="mb-14">
    <span class="badge mb-5">Skills</span>

    <h2 class="section-title">
      A balanced skill set across analytics, finance, and reporting.
    </h2>
  </div>

  <div class="grid md:grid-cols-3 gap-6">
    {Object.entries(skills).map(([group, items]) => (
      <div class="card p-7">
        <h3 class="text-xl font-bold text-white capitalize mb-5">
          {group}
        </h3>

        <div class="flex flex-wrap gap-2">
          {items.map((skill) => (
            <span class="text-sm px-3 py-2 rounded-full bg-slate-900/80 border border-slate-700 text-slate-300">
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
