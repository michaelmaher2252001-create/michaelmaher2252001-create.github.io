---
import "../styles/global.css";

import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Michael Maher | Data & Financial Analyst</title>
    <meta
      name="description"
      content="Portfolio of Michael Maher, a Data and Financial Analyst focused on Power BI dashboards, financial performance analysis, profitability insights, and business decision support."
    />

    <meta property="og:title" content="Michael Maher | Data & Financial Analyst" />
    <meta
      property="og:description"
      content="Power BI dashboards, financial analysis, profitability insights, and business reporting projects."
    />
    <meta property="og:type" content="website" />
  </head>

  <body>
    <main>
      <Hero />
      <About />
      <Projects />
      <Experience />
      <Education />
    </main>
  </body>
</html>
