---
const projects = [
  {
    title: "Fraud Analysis",
    image: "/projects/fraud-analysis.png",
    description: "Fraud analysis dashboard with insights and metrics",
  },
  {
    title: "Financial Performance",
    image: "/projects/financial-performance.png",
    description: "Financial performance and sales analysis dashboard",
  },
  {
    title: "Sales Analysis",
    image: "/projects/sales.png",
    description: "Sales analysis dashboard and KPIs",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Michael Maher | Data Analyst</title>
    <meta
      name="description"
      content="Portfolio website of Michael Maher – Data Analyst"
    />
  </head>

  <body>
    <!-- ===== HEADER / NAV ===== -->
    <header>
      <nav>
        <a href="#hero">Home</a>
        <a href="#about">About</a>
        <a href="#education">Education</a>
        <a href="#projects">Projects</a>
      </nav>
    </header>

    <!-- ===== HERO ===== -->
    <section id="hero">
      <h1>Michael Maher</h1>
      <p>Data Analyst | Business Intelligence | Dashboards</p>
    </section>

    <!-- ===== ABOUT ===== -->
    <section id="about">
      <h2>About Me</h2>
      <p>
        Data Analyst with experience in data visualization, reporting,
        and business insights. Passionate about transforming data into
        actionable decisions.
      </p>
    </section>

    <!-- ===== EDUCATION ===== -->
    <section id="education">
      <h2>Education</h2>
      <ul>
        <li>Bachelor’s Degree in Business / Information Systems</li>
        <li>Data Analytics & Business Intelligence Training</li>
      </ul>
    </section>

    <!-- ===== PROJECTS ===== -->
    <section id="projects">
      <h2>Projects</h2>

      <div class="projects-grid">
        {projects.map((project) => (
          <article class="project-card">
            <img
              src={project.image}
              alt={project.title}
              width="400"
              loading="lazy"
            />
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer>
      <p>© {new Date().getFullYear()} Michael Maher</p>
    </footer>
  </body>
</html>
