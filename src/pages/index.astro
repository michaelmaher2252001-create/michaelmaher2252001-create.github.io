---
const projects = [
  {
    title: "Fraud Analysis",
    image: "/projects/fraud-analysis.png",
    description: "Fraud analysis dashboard with insights and metrics",
  },
  {
    title: "Financial Performance",
    image: "/projects/financial-performance.png",
    description: "Financial performance and sales analysis dashboard",
  },
  {
    title: "Sales Analysis",
    image: "/projects/sales.png",
    description: "Sales analysis dashboard and KPIs",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Michael Maher – Portfolio</title>
    <meta name="description" content="Portfolio projects by Michael Maher" />
  </head>

  <body>
    <main>
      <h1>Projects</h1>

      <section>
        {projects.map((project) => (
          <article>
            <h2>{project.title}</h2>
            <img
              src={project.image}
              alt={project.title}
              style="max-width: 100%; height: auto;"
            />
            <p>{project.description}</p>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>
``
