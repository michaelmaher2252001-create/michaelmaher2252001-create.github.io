---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    title: "Fraud Analysis",
    image: "/projects/fraud-analysis.png",
    description: "Fraud analysis dashboard with insights and metrics",
  },
  {
    title: "Financial Performance",
    image: "/projects/financial-performance.png",
    description: "Financial performance and sales analysis dashboard",
  },
  {
    title: "Sales Analysis",
    image: "/projects/sales.png",
    description: "Sales analysis dashboard and KPIs",
  },
];
---

<Layout>
  <section id="hero">
    <h1>Michael Maher</h1>
    <p>Data Analyst & Business Intelligence Specialist</p>
  </section>

  <section id="about">
    <h2>About</h2>
    <p>
      Data Analyst experienced in dashboards, reporting, and data-driven
      insights.
    </p>
  </section>

  <section id="education">
    <h2>Education</h2>
    <ul>
      <li>Bachelor’s Degree in Business / Information Systems</li>
      <li>Business Intelligence & Data Analytics Training</li>
    </ul>
  </section>

  <section id="projects">
    <h2>Projects</h2>
    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card">
          <img src={project.image} alt={project.title} />
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
